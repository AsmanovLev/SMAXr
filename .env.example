# SMAXr — copy to .env and fill in real values
# .env is gitignored; this file is the public template.

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# OpenCode Go API key (https://opencode.ai)
OPENCODE_API_KEY=sk-...

# SOCKS5 proxy (for networks where api.telegram.org is blocked)
SOCKS_PROXY=socks5h://127.0.0.1:10808

# Default LLM model (must be available on the gateway)
SMAXR_MODEL=minimax-m3
